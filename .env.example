# ============================================================
# SIGNA DISCORD BOT — Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# --- Signa API ---
# Get your key from app.getsigna.ai/dashboard/api-keys → "+ New API Key"
# Format: cmts_... (only shown once at creation)
# Rate limit: Founding plan = 60 req/hr · 1,000 req/day
# The hourly scan consumes ~52 calls (50 tickers + 2 GEX + overhead).
# Remaining budget per hour is used by /signa and /health slash commands.
SIGNA_API_KEY=cmts_your_key_here

# --- Discord webhooks ---
# Required: fallback for all channels not individually configured.
# Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXXX/YYYYYYYYY

# Optional: one webhook per channel for independent routing.
# Any channel left blank falls back to DISCORD_WEBHOOK_URL.
DISCORD_WEBHOOK_SIGNALS=
DISCORD_WEBHOOK_MICRO=
DISCORD_WEBHOOK_MACRO=
DISCORD_WEBHOOK_EARNINGS=
DISCORD_WEBHOOK_DARKPOOL=
DISCORD_WEBHOOK_FOMC=
DISCORD_WEBHOOK_LOOKUPS=
DISCORD_WEBHOOK_BACKTEST=

# Optional: separate high-conviction alerts channel (Tier 3).
# Falls back to DISCORD_WEBHOOK_URL if blank.
DISCORD_ALERTS_WEBHOOK_URL=

# Optional: test channel webhook for --post-test verification (Step 2 of §8).
# Set this to a #test channel webhook to avoid posting to live channels.
DISCORD_TEST_WEBHOOK_URL=

# --- Discord Gateway Bot (slash commands: /signa, /health) ---
# Create a bot at discord.com/developers/applications → Add Bot → OAuth2
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# --- Watchlist ---
# Comma-separated tickers, max 50 (rate budget: 50 tickers + 2 GEX + overhead ≤ 58/hr).
# Note: tickers with non-alphanumeric characters (e.g. BRK.B) are not supported by the
# /signal endpoint's `sym=` parameter — remap to the broker-style alias or omit.
WATCHLIST=NVDA,AAPL,MSFT,GOOGL,AMZN,SPY,QQQ,META,TSLA

# --- Schedule (all times in ET / America/New_York) ---
# Hourly scan fires every hour Mon–Fri (cron: 0 * * * 1-5). Not configurable.
# Nightly digest fires at DIGEST_HOUR:DIGEST_MINUTE on weekdays.
DIGEST_HOUR=21
DIGEST_MINUTE=30

# Pre-market brief at 09:00 ET (regime + screener)
ENABLE_PREMARKET=true
