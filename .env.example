# ============================================================
# SIGNA DISCORD BOT — Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# --- Signa API ---
# Get your key from app.getsigna.ai/dashboard/api-keys → "+ New API Key"
# Format: cmts_... (only shown once at creation)
SIGNA_API_KEY=cmts_your_key_here

# --- Discord webhooks ---
# Server Settings → Integrations → Webhooks → New Webhook
# Pick the channel, copy the URL.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXXX/YYYYYYYYY

# Optional: separate channel for Tier 3 (high-conviction) alerts only.
# Falls back to DISCORD_WEBHOOK_URL if blank.
DISCORD_ALERTS_WEBHOOK_URL=

# --- Watchlist ---
# Comma-separated tickers, max 50.
WATCHLIST=NVDA,AAPL,MSFT,GOOGL,AMZN,SPY,QQQ,META,TSLA,BRK.B

# --- Schedule (all times in ET / America/New_York) ---
# Nightly digest fires at DIGEST_HOUR:DIGEST_MINUTE on weekdays.
# Pipeline runs at 21:05 ET — schedule digest after that (e.g. 21:30).
DIGEST_HOUR=21
DIGEST_MINUTE=30

# --- Dark pool monitoring ---
# Single ticker watched every 30 min during market hours.
DARKPOOL_TICKER=SPY

# --- Optional jobs (true/false) ---
# Midday Tier 3 sweep at 12:30 ET
ENABLE_MIDDAY_CHECK=true

# Pre-market brief at 09:00 ET (earnings + active signals)
ENABLE_PREMARKET=true
